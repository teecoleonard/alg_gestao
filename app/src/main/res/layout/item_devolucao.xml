<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="2dp"
    android:layout_marginHorizontal="8dp"
    app:cardBackgroundColor="@color/card_returns_bg"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/card_returns_accent"
    app:strokeWidth="0.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <!-- Status da devolução - Ícone compacto -->
        <ImageView
            android:id="@+id/ivStatusDevolucao"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="Status da devolução"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/llInfoPrincipal"
            app:layout_constraintBottom_toBottomOf="@+id/llInfoPrincipal"
            tools:src="@drawable/ic_pending"
            tools:tint="@color/warning" />

        <!-- Informações principais em formato compacto -->
        <LinearLayout
            android:id="@+id/llInfoPrincipal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@+id/ivStatusDevolucao"
            app:layout_constraintEnd_toStartOf="@+id/ivMenuDevolucao"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Linha 1: Nome do Cliente + Número da Devolução -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvClienteNome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                    android:textColor="@color/card_returns_accent"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="CENTRO DE TREINAMENTO BASE SPORTING" />

                <TextView
                    android:id="@+id/tvDevolucaoNumero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="#123" />

            </LinearLayout>

            <!-- Linha 2: Equipamento + Quantidade -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvEquipamentoNome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Plataforma Elevatória" />

                <TextView
                    android:id="@+id/tvQuantidades"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    tools:text="3/5" />

            </LinearLayout>

        </LinearLayout>

        <!-- Menu de opções - Compacto -->
        <ImageView
            android:id="@+id/ivMenuDevolucao"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Menu de opções"
            android:focusable="true"
            android:padding="2dp"
            android:src="@drawable/ic_more_vert"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/llInfoPrincipal"
            app:layout_constraintBottom_toBottomOf="@+id/llInfoPrincipal"
            app:tint="@color/card_returns_accent" />

        <!-- Campos ocultos para compatibilidade (para não quebrar o código existente) -->
        <TextView
            android:id="@+id/tvDataPrevista"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDataEfetiva"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
