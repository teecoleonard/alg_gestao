<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/card_equipment_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/card_equipment_accent"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNomeMaterial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.ALG.Title"
            android:textColor="@color/card_equipment_accent"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/ivMenuMaterial"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Cimento CP-II" />

        <ImageView
            android:id="@+id/ivMenuMaterial"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Opcoes"
            android:src="@drawable/ic_more_vert"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/card_equipment_accent" />

        <TextView
            android:id="@+id/tvCodigoMaterial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.ALG.Body"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvNomeMaterial"
            app:layout_constraintTop_toBottomOf="@id/tvNomeMaterial"
            tools:text="Codigo: MAT-001" />

        <TextView
            android:id="@+id/tvQuantidadeMaterial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.ALG.Body"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toStartOf="@id/tvBadgeDisponibilidade"
            app:layout_constraintStart_toStartOf="@id/tvNomeMaterial"
            app:layout_constraintTop_toBottomOf="@id/tvCodigoMaterial"
            tools:text="Total: 150" />

        <TextView
            android:id="@+id/tvBadgeDisponibilidade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_status_active"
            android:backgroundTint="@color/success"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textAppearance="@style/TextAppearance.ALG.Caption"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCodigoMaterial"
            tools:text="95 disp." />

        <TextView
            android:id="@+id/tvValorUnitarioMaterial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_active"
            android:backgroundTint="@color/card_equipment_accent"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textAppearance="@style/TextAppearance.ALG.Body"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvNomeMaterial"
            app:layout_constraintTop_toBottomOf="@id/tvQuantidadeMaterial"
            tools:text="Unitario: R$ 35,00" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
